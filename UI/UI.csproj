<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/14.0.2">

  <PropertyGroup>
    <RootNamespace>Echotools.UI</RootNamespace>
    <AssemblyName>Echotools.UI</AssemblyName>
    <Version>1.0.0</Version>
    <Description>Shared UI components for Echotools Dalamud plugins</Description>
    <PackageProjectUrl>https://github.com/RenNagasaki/Echotools</PackageProjectUrl>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TargetFramework>net10.0-windows</TargetFramework>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x64' ">
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Remove="DalamudPackager" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\KamiToolKit\KamiToolKit.csproj" />
  </ItemGroup>

</Project>
